# ── Email (Gmail SMTP) ─────────────────────────────────────────────────────────
EMAIL_SENDER=tu_email@gmail.com
EMAIL_PASSWORD=tu_app_password         # Gmail App Password (16 chars)
EMAIL_RECIPIENT=destinatario@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── Telegram ───────────────────────────────────────────────────────────────────
# 1. Creá un bot con @BotFather en Telegram y copiá el token
# 2. Enviá cualquier mensaje al bot, luego abrí:
#    https://api.telegram.org/bot<TOKEN>/getUpdates  → copiá chat.id
TELEGRAM_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=987654321

# ── WhatsApp (CallMeBot — gratis, uso personal) ────────────────────────────────
# 1. Agregá al contacto +34 644 59 32 96
# 2. Enviá este mensaje: "I allow callmebot to send me messages"
# 3. Recibirás tu API key por WhatsApp
WHATSAPP_PHONE=+5491112345678          # Tu número con código de país
WHATSAPP_API_KEY=tu_callmebot_api_key
